{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LOY-TUNER",
  "version": "0.1.0",
  "identifier": "com.mzatuner.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "LOY-TUNER 2026",
        "label": "main",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 700,
        "decorations": true,
        "transparent": false,
        "visible": true,
        "fullscreen": false,
        "resizable": true,
        "center": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Honda Keihin / Shinden ECU flasher",
    "longDescription": "LOY-TUNER is a Tauri-based GUI for flashing and tuning Honda motorcycle ECUs (Keihin and Shinden families) over the K-Line protocol via an FTDI USB-Serial adapter."
  }
}
